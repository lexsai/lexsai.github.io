---
title: lexsai
---

<html>
    <head>
        <title>{{ title }} - lexsai</title>
        <link rel="icon" href="/images/favicon2.png">
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="wrapper">
            <canvas id="background" width="1000" height="1000"></canvas> 
            <header>
                <nav>
                    <a href="/index.html">HOME</a>
                    <a href="/archive/">POSTS</a>
                    <a href="/projects/">PROJECTS</a>
                </nav> 
            </header>
            <main>
                <div class="border-container">
                    <h1 class="page-title" id="page-title">{{ title }}</h1>
                    <div class="date">{% formatDate date %}</div>
                    <section class="post-text">
                        {{ content }}
                    </section>
                </div>
            </main>
            <footer>
            </footer>
        </div>

        <script>
            let pageTitleElement = document.getElementById("page-title");
            if (pageTitleElement.innerText.length > 15) {
                pageTitleElement.classList.add("medium-text")
            }
        </script>
        <script src="/scripts/background.js"></script>
    </body>
</html>
